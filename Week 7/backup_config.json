{
  "metadata": {
    "plan_name": "Backup of Critical Security Logs",
    "version": "1.0",
    "created_by": "Carsen Hintz",
    "description": "Daily backup of critical security logs"
  },
  "sources": [
    {
      "name": "Firewall Logs",
      "path": "/var/log/firewall",
      "recursive": true,
      "include_patterns": ["*.log"],
      "exclude_patterns": ["debug_*"]
    },
    {
      "name": "Authentication Logs",
      "path": "/var/log/auth",
      "recursive": false,
      "include_patterns": ["*.log", "*.txt"],
      "exclude_patterns": []
    }
  ],
  "destination": {
    "base_path": "/backup/security",
    "create_timestamped_folders": true,
    "retention_days": 30
  },
  "options": {
    "verify_backups": true,
    "max_file_size_mb": 50
  }
}